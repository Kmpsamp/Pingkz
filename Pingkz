        imgui.SetNextWindowPos(imgui.ImVec2(ini.cfg.posX, ini.cfg.posY), imgui.Cond.Always)
        imgui.Begin("##HUD_KAIZER", nil, flags)
            -- Sincronización de posición si se arrastra
            local pos = imgui.GetWindowPos()
