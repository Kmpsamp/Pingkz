            imgui.Text("Informacion")
            imgui.TextColored(imgui.ImVec4(0.25, 0.75, 0.25, 1.0), "Kaizer X ByMortis")
            imgui.Separator()
            imgui.Text("Version: 1.3")
            imgui.Text("Comandos: /gp")
        end
        imgui.EndChild()
        imgui.End()
    end
end)

-- ================= SOPORTE =================
function sampev.onSendGiveDamage(playerId)
    targetID, damageTime = playerId, os.clock()
end

function getBonePos(charHandle, boneID)
    if not charHandle or charHandle == 0 then return 0,0,0 end
    local pedPtr = ffi.cast("void*", getCharPointer(charHandle))
    local vec = ffi.new("Vec3[1]")
    if gta_sa then pcall(function() gta_sa._ZN4CPed15GetBonePositionER5RwV3djb(pedPtr, vec, boneID, false) end) end
    return vec[0].x, vec[0].y, vec[0].z
end

function getArea(x, y, z)
    local streets = {
            {"Los Santos", 44.615, -2892.970, -242.990, 2997.060, -768.027, 900.000}
    }
    for _, v in ipairs(streets) do
        if (x >= v[2]) and (y >= v[3]) and (z >= v[4]) and (x <= v[5]) and (y <= v[6]) and (z <= v[7]) then return v[1] end
    end
    return "San Andreas"
end
