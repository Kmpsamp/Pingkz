                ini.cfg.posX, ini.cfg.posY = math.floor(pos.x), math.floor(pos.y)
                sliderX[0], sliderY[0] = ini.cfg.posX, ini.cfg.posY
            end

            local curColor = imgui.ImVec4(colorHUD[0], colorHUD[1], colorHUD[2], colorHUD[3])
            imgui.TextColored(curColor, getArea(x, y, z))
            imgui.TextColored(curColor, string.format("Ping: %d", sampGetPlayerPing(myId) or 0))
            imgui.TextColored(curColor, string.format("Fps: %d", math.floor(imgui.GetIO().Framerate)))
        imgui.End()
    end

    -- 2. MENÚ SIDEBAR SOFT BLACK
    if menuOpen[0] then
        local sw, sh = getScreenResolution()
        imgui.SetNextWindowSize(imgui.ImVec2(550, 350), imgui.Cond.FirstUseEver)
        imgui.Begin("Display Ping", menuOpen)

        imgui.BeginChild("Sidebar", imgui.ImVec2(160, 0), true)
        imgui.CustomMenu(tabs, tab, imgui.ImVec2(150, 45))
        imgui.EndChild()

        imgui.SameLine()

        imgui.BeginChild("Content", imgui.ImVec2(0, 0), true)
